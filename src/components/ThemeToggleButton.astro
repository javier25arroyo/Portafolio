---
// src/components/ThemeToggleButton.astro
---
<button id="theme-toggle" class="theme-toggle-btn" type="button" aria-label="Toggle theme" role="button" tabindex="0">
  <svg id="theme-toggle-dark-icon" class="theme-icon dark-icon" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>
  <svg id="theme-toggle-light-icon" class="theme-icon light-icon" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
    <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.121-3.536a1 1 0 010 1.414l-.707.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM10 18a1 1 0 01-1-1v-1a1 1 0 112 0v1a1 1 0 01-1 1zM4.95 15.464l.707-.707a1 1 0 10-1.414-1.414l-.707.707a1 1 0 001.414 1.414zM2.707 6.707a1 1 0 010-1.414l.707-.707a1 1 0 111.414 1.414l-.707.707a1 1 0 01-1.414 0zM4 10a1 1 0 01-1-1H2a1 1 0 110-2h1a1 1 0 110 2zm13-1a1 1 0 100-2h-1a1 1 0 100 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
  </svg>
</button>

<style>
  .theme-toggle-btn {
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    color: var(--text-primary);
    padding: 0.5rem;
    border-radius: 9999px;
    transition: all var(--transition-normal);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-width: 44px;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
  }
  
  .theme-toggle-btn:hover {
    background-color: var(--bg-accent);
    transform: scale(1.05);
    border-color: var(--border-light);
  }
  
  .theme-toggle-btn:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.3);
    border-color: var(--color-primary);
  }
  
  .theme-toggle-btn:active {
    transform: scale(0.98);
  }
  
  .theme-icon {
    width: 1.5rem;
    height: 1.5rem;
    display: none;
    transition: all var(--transition-normal);
  }
  
  .theme-icon.visible {
    display: block;
  }
  
  /* Estados específicos para cada tema */
  html:not(.dark) .light-icon {
    display: block;
  }
  
  html.dark .dark-icon {
    display: block;
  }
  
  /* Soporte para dispositivos móviles */
  @media (max-width: 768px) {
    .theme-toggle-btn {
      min-width: 48px;
      min-height: 48px;
      padding: 0.625rem;
    }
    
    .theme-icon {
      width: 1.25rem;
      height: 1.25rem;
    }
  }
  
  /* Soporte para modo alto contraste */
  @media (prefers-contrast: high) {
    .theme-toggle-btn {
      border-color: var(--text-primary);
    }
    
    .theme-toggle-btn:hover {
      background-color: var(--text-primary);
      color: var(--bg-primary);
    }
  }
  
  /* Animación de rotación suave */
  .theme-toggle-btn:hover .theme-icon {
    transform: rotate(15deg);
  }
</style>
