---
import Button from './Button.astro';
---
<!-- 🎨 Hero Section Optimizado para Performance -->
<section id="home" class="min-h-screen relative overflow-hidden hero-bg">
  
  <!-- Contenido principal con animaciones optimizadas -->
  <div class="relative z-10 flex items-center justify-center min-h-screen pt-20 md:pt-24">
    <div class="container mx-auto px-6 py-12">
      
      <!-- Header con introducción -->
      <div class="text-left mb-8 reveal hero-intro">
        <!-- Greeting -->
        <div class="greeting-container mb-4">
          <p class="text-2xl md:text-3xl font-light reveal greeting-text">
            <span class="greeting-word" data-i18n="greeting" data-i18n-en="Hi," data-i18n-es="Hola,">Hi,</span>
            <span class="greeting-word" data-i18n="greeting2" data-i18n-en="I'm" data-i18n-es="soy">I'm</span>
            <span class="name-highlight">Javier Arroyo</span>
          </p>
        </div>

        <!-- Título principal -->
        <h1 class="text-6xl md:text-8xl font-bold leading-tight mb-6 hero-title">
          <span class="block reveal title-first" data-i18n="title1" data-i18n-en="Software" data-i18n-es="Desarrollador">Software</span>
          <span class="block gradient-text reveal title-second" data-i18n="title2" data-i18n-en="Developer" data-i18n-es="de Software">Developer</span>
        </h1>
      </div>

      <!-- Descripción — frase de valor -->
      <div class="max-w-3xl mb-12 reveal hero-description">
        <p class="text-xl md:text-2xl leading-relaxed hero-phrase" data-i18n="hero-phrase" data-i18n-en="Where cutting-edge and stability are not a compromise." data-i18n-es="Donde vanguardia y estabilidad no son un compromiso.">
          Where cutting-edge and stability are not a compromise.
        </p>
      </div>

      <!-- CTAs optimizados -->
      <div class="flex flex-col sm:flex-row gap-6 mb-12 reveal hero-ctas">
        <a href="#projects" class="btn-primary group inline-flex items-center justify-center gap-3 hover-lift" data-track="hero-view-work" rel="nofollow">
          <span data-i18n="cta1" data-i18n-en="View My Work" data-i18n-es="Ver mi Trabajo">View My Work</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        
        <a href="#contact" class="btn-secondary group inline-flex items-center justify-center gap-3 hover-lift" data-track="hero-lets-connect" rel="nofollow">
          <span data-i18n="cta2" data-i18n-en="Let's Connect" data-i18n-es="Conectemos">Let's Connect</span>
          <svg class="w-5 h-5 transform group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </a>
      </div>

      <!-- Scroll indicator optimizado -->
      <div class="absolute bottom-16 left-1/2 transform -translate-x-1/2 scroll-indicator z-10" aria-hidden="true">
        <div class="flex flex-col items-center gap-2 scroll-text">

          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 🎨 Estilos optimizados para performance -->
<style>
  /* === BACKGROUND === */
  .hero-bg {
    background: linear-gradient(180deg, #0B0D17 0%, #0E1420 100%);
    position: relative;
    will-change: auto;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 60%, rgba(37, 99, 235, 0.10) 0%, transparent 55%);
    pointer-events: none;
    z-index: -1;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(241, 245, 249, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(241, 245, 249, 0.015) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.4;
    pointer-events: none;
    z-index: -1;
  }

  /* === ANIMACIONES OPTIMIZADAS === */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* === GREETING EFFECTS SIMPLIFICADOS === */
  .greeting-container {
    position: relative;
  }

  .greeting-text {
    color: #CBD5E1;
    position: relative;
  }

  .greeting-word {
    display: inline-block;
    margin-right: 0.5rem;
  }

  /* === NAME HIGHLIGHT === */
  .name-highlight {
    position: relative;
    display: inline-block;
    font-weight: 600;
    color: #3B82F6;
  }

  .hero-title {
    color: #F1F5F9;
  }

  .title-first,
  .title-second {
    display: block;
  }

  /* gradient-text viene de global.css (azul→dorado) */

  /* === HERO PHRASE === */
  .hero-phrase {
    color: #94A3B8;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  /* === SCROLL INDICATOR === */
  .scroll-indicator {
    animation: bounce 2s infinite;
  }

  .scroll-text {
    color: #94A3B8;
  }

  /* === KEYFRAMES === */
  @keyframes bounce {
    0%, 20%, 53%, 80%, 100% {
      transform: translate3d(0, 0, 0);
    }
    40%, 43% {
      transform: translate3d(0, -8px, 0);
    }
    70% {
      transform: translate3d(0, -4px, 0);
    }
    90% {
      transform: translate3d(0, -2px, 0);
    }
  }

  /* === RESPONSIVE OPTIMIZADO === */
  @media (max-width: 768px) {
    .text-6xl {
      font-size: 3rem;
      line-height: 1.1;
    }
    
    .md\:text-8xl {
      font-size: 4rem;
      line-height: 1;
    }
    
    .text-xl {
      font-size: 1.125rem;
    }
    
    .md\:text-2xl {
      font-size: 1.25rem;
    }
    
    .hero-bg > div {
      padding-top: 4rem !important;
      padding-bottom: 2rem;
    }

    .greeting-text {
      font-size: 1.5rem;
    }
    
    .name-highlight {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .greeting-text {
      font-size: 1.25rem;
    }
    
    .name-highlight {
      font-size: 1.5rem;
    }

    .text-6xl {
      font-size: 2.5rem;
    }

    .md\:text-8xl {
      font-size: 3rem;
    }
  }

  /* === ACCESSIBILITY === */
  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .scroll-indicator {
      animation: none;
      transition: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
  }

  /* === GPU ACCELERATION SOLO DONDE ES NECESARIO === */
  .hover-lift {
    transition: transform 0.2s ease-out;
  }

  .hover-lift:hover {
    transform: translateY(-2px);
  }

  .group:hover .group-hover\:translate-x-1 {
    transform: translateX(0.25rem);
  }

  .group:hover .group-hover\:scale-110 {
    transform: scale(1.1);
  }
</style>