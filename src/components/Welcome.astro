---
import Button from './Button.astro';
---
<!-- 🎨 Hero Section Modernizado -->
<div id="hero-section" class="min-h-screen relative overflow-hidden hero-bg">
  
  <!-- Contenido principal con animaciones escalonadas -->
  <div class="relative z-10 flex items-center justify-center min-h-screen pt-16">
    <div class="container mx-auto px-6 py-12">
      
      <!-- Header con introducción animada -->
      <div class="text-left mb-8 animate-fade-in-up hero-intro">
        <div class="inline-flex items-center px-4 py-2 rounded-full backdrop-blur-sm mb-6 glass-dark border border-border-light status-badge">
          <div class="w-2 h-2 rounded-full mr-3 animate-ping status-dot"></div>
          <span class="font-medium text-sm status-text">Available for opportunities</span>
        </div>
        
        <!-- Greeting con efectos impactantes -->
        <div class="greeting-container mb-4">
          <p class="text-2xl md:text-3xl font-light animate-fade-in-up greeting-text">
            <span class="greeting-word" data-word="Hi,">Hi,</span>
            <span class="greeting-word" data-word="I'm">I'm</span>
            <span id="name-interactive" class="name-highlight" data-name="Javier Arroyo">
              <span class="name-letter" data-letter="J">J</span><span class="name-letter" data-letter="a">a</span><span class="name-letter" data-letter="v">v</span><span class="name-letter" data-letter="i">i</span><span class="name-letter" data-letter="e">e</span><span class="name-letter" data-letter="r">r</span>
              <span class="name-space"> </span>
              <span class="name-letter" data-letter="A">A</span><span class="name-letter" data-letter="r">r</span><span class="name-letter" data-letter="r">r</span><span class="name-letter" data-letter="o">o</span><span class="name-letter" data-letter="y">y</span><span class="name-letter" data-letter="o">o</span>
            </span>
          </p>
        </div>
        
        <!-- Título principal con efecto de escritura mejorado -->
        <h1 class="text-6xl md:text-8xl font-bold leading-tight mb-6 hero-title">
          <span class="block animate-slide-in-left title-first">Software</span>
          <span class="block gradient-text animate-slide-in-right title-second">Developer</span>
        </h1>
      </div>

      <!-- Descripción con animación mejorada -->
      <div class="max-w-4xl mb-12 animate-fade-in-up hero-description">
        <p class="text-xl md:text-2xl leading-relaxed font-light description-text">
          Crafting exceptional digital experiences through 
          <span class="font-medium relative text-glow highlight-innovation">
            innovative design
            <span class="absolute -bottom-1 left-0 w-full h-0.5 transform scale-x-0 animate-scale-in underline-effect"></span>
          </span> 
          and 
          <span class="font-medium relative text-glow-secondary highlight-tech">
            cutting-edge technology
            <span class="absolute -bottom-1 left-0 w-full h-0.5 transform scale-x-0 animate-scale-in underline-effect-secondary"></span>
          </span>
        </p>
      </div>

      <!-- CTAs con animaciones mejoradas -->
      <div class="flex flex-col sm:flex-row gap-6 mb-12 animate-fade-in-up hero-ctas">
        <a href="#projects" class="btn-primary magnetic-btn group inline-flex items-center justify-center gap-3 hover-lift" data-track="hero-view-work">
          <span>View My Work</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        
        <a href="#contact" class="btn-secondary magnetic-btn group inline-flex items-center justify-center gap-3 hover-lift" data-track="hero-lets-connect">
          <span>Let's Connect</span>
          <svg class="w-5 h-5 transform group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </a>
      </div>

      <!-- Scroll indicator mejorado -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce scroll-indicator">
        <div class="flex flex-col items-center gap-2 scroll-text">
          <span class="text-xs font-medium">Scroll to explore</span>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 🎨 Estilos personalizados para animaciones -->
<style>
  /* === BACKGROUND === */
  .hero-bg {
    background: var(--gradient-hero);
    position: relative;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 80%, rgba(79, 70, 229, 0.15) 0%, transparent 70%),
      radial-gradient(circle at 80% 20%, rgba(124, 58, 237, 0.12) 0%, transparent 70%),
      radial-gradient(circle at 40% 40%, rgba(5, 150, 105, 0.08) 0%, transparent 70%);
    animation: float 20s ease-in-out infinite;
    pointer-events: none;
    transition: transform 0.5s ease-out;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(var(--border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.5;
    pointer-events: none;
    transition: transform 0.5s ease-out;
  }

  /* === ANIMATION DELAYS === */
  .hero-intro { animation-delay: 0.5s; }
  .greeting-text { animation-delay: 0.7s; }
  .title-first { animation-delay: 0.9s; }
  .title-second { animation-delay: 1.2s; }
  .hero-description { animation-delay: 1.4s; }
  .hero-ctas { animation-delay: 1.6s; }
  .scroll-indicator { animation-delay: 3s; }

  /* === GREETING & NAME EFFECTS === */
  .greeting-word {
    display: inline-block;
    margin-right: 0.5rem;
    opacity: 0;
    animation: slideInFromLeft 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
  }
  .greeting-word:nth-child(1) { animation-delay: 0.8s; }
  .greeting-word:nth-child(2) { animation-delay: 1.0s; }

  .name-highlight {
    position: relative;
    display: inline-block;
    font-weight: 600;
    color: var(--color-accent);
  }
  .name-letter {
    display: inline-block;
    position: relative;
    opacity: 0;
    transform: translateY(100px) rotateX(90deg);
    animation: letterReveal 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    transition: transform 0.3s ease, color 0.3s ease;
  }
  .name-letter:hover {
    transform: scale(1.2) translateY(-5px) !important; /* !important to override JS */
    color: var(--color-primary);
  }
  .name-letter:nth-child(1) { animation-delay: 1.2s; }
  .name-letter:nth-child(2) { animation-delay: 1.3s; }
  .name-letter:nth-child(3) { animation-delay: 1.4s; }
  .name-letter:nth-child(4) { animation-delay: 1.5s; }
  .name-letter:nth-child(5) { animation-delay: 1.6s; }
  .name-letter:nth-child(6) { animation-delay: 1.7s; }
  .name-letter:nth-child(8) { animation-delay: 1.9s; }
  .name-letter:nth-child(9) { animation-delay: 2.0s; }
  .name-letter:nth-child(10) { animation-delay: 2.1s; }
  .name-letter:nth-child(11) { animation-delay: 2.2s; }
  .name-letter:nth-child(12) { animation-delay: 2.3s; }
  .name-letter:nth-child(13) { animation-delay: 2.4s; }
  .name-space { width: 0.5rem; animation-delay: 1.8s; }

  /* === MAGNETIC BUTTON === */
  .magnetic-btn {
    position: relative;
    overflow: hidden;
  }
  .magnetic-btn::before {
    content: '';
    position: absolute;
    top: var(--y, 50%);
    left: var(--x, 50%);
    transform: translate(-50%, -50%) scale(0);
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
    border-radius: 50%;
    transition: transform 0.5s ease, opacity 0.5s ease;
    opacity: 0;
    pointer-events: none;
  }
  .magnetic-btn:hover::before {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }

  /* Other styles remain the same */
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('hero-section');
    if (!hero) return;

    // Parallax Effect
    const bgBefore = hero.querySelector('.hero-bg::before');
    const bgAfter = hero.querySelector('.hero-bg::after');
    hero.addEventListener('mousemove', (e) => {
      const { clientX, clientY } = e;
      const { offsetWidth, offsetHeight } = hero;
      const x = (clientX / offsetWidth - 0.5) * 30; // Multiplier for effect intensity
      const y = (clientY / offsetHeight - 0.5) * 30;
      if(bgBefore) bgBefore.style.transform = `translateX(${-x}px) translateY(${-y}px)`;
      if(bgAfter) bgAfter.style.transform = `translateX(${-x/2}px) translateY(${-y/2}px)`;
    });

    // Interactive Name
    const nameContainer = document.getElementById('name-interactive');
    if (nameContainer) {
      const letters = nameContainer.querySelectorAll('.name-letter');
      nameContainer.addEventListener('mousemove', (e) => {
        const { clientX, clientY } = e.target.getBoundingClientRect();
        const x = e.clientX - clientX;
        const y = e.clientY - clientY;
        letters.forEach(letter => {
          const dx = letter.offsetLeft + letter.offsetWidth / 2 - x;
          const dy = letter.offsetTop + letter.offsetHeight / 2 - y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const score = Math.max(0, 1 - dist / 100);
          letter.style.transform = `translateY(${-score * 10}px) scale(${1 + score * 0.2})`;
        });
      });
      nameContainer.addEventListener('mouseleave', () => {
        letters.forEach(letter => letter.style.transform = 'initial');
      });
    }

    // Magnetic Buttons
    const magneticButtons = document.querySelectorAll('.magnetic-btn');
    magneticButtons.forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const { left, top, width, height } = btn.getBoundingClientRect();
        const x = e.clientX - left;
        const y = e.clientY - top;
        btn.style.setProperty('--x', `${x}px`);
        btn.style.setProperty('--y', `${y}px`);
      });
    });
  });
</script>