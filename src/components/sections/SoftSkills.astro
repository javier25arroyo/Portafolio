---
import { softSkills } from '../../data/softSkills';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
---
<section class="section" aria-labelledby="soft-skills-title">
  <Container>
    <SectionHeading
      id="soft-skills-title"
      eyebrow="Forma de trabajar"
      title="La calidad técnica también depende de cómo se piensa."
    />
    <ul class="soft-skills-list" role="list">
      {softSkills.map((skill, index) => (
        <li class="soft-skills-list__item">
          <span class="soft-skills-list__num" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div class="soft-skills-list__body">
            <span class="soft-skills-list__title">{skill.title}</span>
            <span class="soft-skills-list__desc">{skill.description}</span>
          </div>
        </li>
      ))}
    </ul>
  </Container>
</section>
