---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
---
<section class="section section--contact" id="contacto" aria-labelledby="contact-title">
  <Container>
    <div class="contact-panel">
      <p class="eyebrow">Conversemos</p>
      <h2 id="contact-title">¿Tienes un proyecto?</h2>
      <p>Estoy abierto a oportunidades de software, colaboraciones y proyectos donde la tecnología deba producir un resultado concreto.</p>
      <div class="contact-panel__actions">
        <Button href="mailto:javier25arojas@gmail.com">Escribirme por email</Button>
        <Button href="https://www.linkedin.com/in/javier-arroyo-268147226/" target="_blank" variant="secondary">Conectar en LinkedIn</Button>
      </div>
    </div>
  </Container>
</section>
