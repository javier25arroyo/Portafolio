---
interface Props { id?: string; eyebrow: string; title: string; description?: string; align?: 'start' | 'center' }
const { id, eyebrow, title, description, align = 'start' } = Astro.props;
---
<div class:list={['section-heading', { 'section-heading--center': align === 'center' }]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 id={id}>{title}</h2>
  {description && <p class="section-heading__description">{description}</p>}
</div>
