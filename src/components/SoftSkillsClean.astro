---
// Interactive Soft Skills Component with Physics Simulation (Corrected)
---

<div id="soft-skills-container" class="relative w-full max-w-4xl mx-auto my-16 reveal">
  <div id="bubbles-canvas" class="w-full min-h-[400px] rounded-2xl glass-premium overflow-hidden">
    <!-- Bubbles are injected here by JS -->
  </div>
</div>

<style>
  /* Mobile-first: Default to a static, touch-friendly grid */
  #bubbles-canvas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    padding: 1.5rem;
    align-content: center;
    justify-content: center;
  }

  .bubble {
    position: relative;
    background: radial-gradient(circle at 30% 30%, var(--bg-accent) 0%, var(--bg-elevated) 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--text-primary);
    font-weight: 600;
    box-shadow: inset 0 0 10px rgba(255,255,255,0.1), 0 10px 20px rgba(0,0,0,0.2);
    transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
    user-select: none;
    aspect-ratio: 1 / 1; /* Maintain circular shape */
    padding: 0.5rem;
  }

  .bubble span {
      font-size: 0.85rem;
  }

  /* Apply a subtle press effect on touch */
  .bubble:active {
      transform: scale(0.95);
  }

  /* --- Desktop-only Physics Animation (Progressive Enhancement) --- */
  /* This media query activates the physics simulation for tablets (landscape) and up */
  @media (min-width: 769px) {
    #bubbles-canvas {
        display: block; /* Revert to block for absolute positioning */
        height: 500px;
        cursor: grab;
    }
    #bubbles-canvas:active {
        cursor: grabbing;
    }
    .bubble {
        position: absolute; /* Enable absolute positioning for physics */
    }
    .bubble:hover {
        transform: scale(1.1);
        box-shadow: inset 0 0 15px rgba(255,255,255,0.2), 0 15px 30px rgba(0,0,0,0.3), 0 0 20px var(--color-primary);
        z-index: 10;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('bubbles-canvas');
    if (!canvas) return;

    const skills = [
      "Effective Communication", "Teamwork", "Collaboration", "Problem-Solving", 
      "Critical Thinking", "Adaptability", "Continuous Learning", "Time Management",
      "Attention to Detail", "Proactivity", "Resilience"
    ];

    let bubbles = [];
    let mouse = { x: null, y: null, radius: 150 };
    let animationFrameId;

    class Bubble {
      constructor(skill, x, y, vx, vy, radius) {
        this.skill = skill;
        this.x = x;
        this.y = y;
        this.vx = vx;
        this.vy = vy;
        this.radius = radius;
        this.element = document.createElement('div');
        this.element.className = 'bubble';
        this.element.style.width = `${radius * 2}px`;
        this.element.style.height = `${radius * 2}px`;
        this.element.innerHTML = `<span>${skill}</span>`;
        // Set initial position using transform for performance
        this.element.style.transform = `translate(${this.x - this.radius}px, ${this.y - this.radius}px)`;
        canvas.appendChild(this.element);
      }

      update(allBubbles, mouse) {
        // Wall collision
        if (this.x + this.radius >= canvas.clientWidth || this.x - this.radius <= 0) this.vx = -this.vx;
        if (this.y + this.radius >= canvas.clientHeight || this.y - this.radius <= 0) this.vy = -this.vy;

        // Mouse repulsion
        if (mouse.x && mouse.y) {
            let dx = this.x - mouse.x;
            let dy = this.y - mouse.y;
            let distance = Math.sqrt(dx * dx + dy * dy);
            if (distance < mouse.radius + this.radius) {
              let force = (mouse.radius + this.radius - distance) / (mouse.radius + this.radius);
              this.vx += (dx / distance) * force * 2;
              this.vy += (dy / distance) * force * 2;
            }
        }

        // Bubble-to-bubble collision
        allBubbles.forEach(other => {
          if (this === other) return;
          let dx = other.x - this.x;
          let dy = other.y - this.y;
          let distance = Math.sqrt(dx * dx + dy * dy);
          if (distance < this.radius + other.radius) {
            let overlap = 0.5 * (distance - this.radius - other.radius);
            this.x += overlap * (this.x - other.x) / distance;
            this.y += overlap * (this.y - other.y) / distance;
            other.x -= overlap * (this.x - other.x) / distance;
            other.y -= overlap * (this.y - other.y) / distance;
            [this.vx, other.vx] = [other.vx, this.vx];
            [this.vy, other.vy] = [other.vy, this.vy];
          }
        });

        this.x += this.vx;
        this.y += this.vy;
        this.vx *= 0.995; // Damping to prevent infinite speed
        this.vy *= 0.995;

        this.element.style.transform = `translate(${this.x - this.radius}px, ${this.y - this.radius}px)`;
      }
    }

    function runSimulation() {
      bubbles.forEach(bubble => bubble.update(bubbles, mouse));
      animationFrameId = requestAnimationFrame(runSimulation);
    }

    function setup() {
      canvas.innerHTML = '';
      bubbles = [];
      cancelAnimationFrame(animationFrameId);

      const isDesktop = window.matchMedia("(min-width: 769px)").matches;

      if (isDesktop) {
        const sizes = [65, 75, 85];
        skills.forEach(skill => {
          let radius = sizes[Math.floor(Math.random() * sizes.length)];
          let x = Math.random() * (canvas.clientWidth - radius * 2) + radius;
          let y = Math.random() * (canvas.clientHeight - radius * 2) + radius;
          let vx = (Math.random() - 0.5) * 1.5;
          let vy = (Math.random() - 0.5) * 1.5;
          bubbles.push(new Bubble(skill, x, y, vx, vy, radius));
        });
        runSimulation();
      } else {
        skills.forEach(skill => {
          const bubbleEl = document.createElement('div');
          bubbleEl.className = 'bubble';
          bubbleEl.innerHTML = `<span>${skill}</span>`;
          canvas.appendChild(bubbleEl);
        });
      }
    }

    canvas.addEventListener('mousemove', e => {
      if (window.matchMedia("(min-width: 769px)").matches) {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      }
    });

    canvas.addEventListener('mouseleave', () => { mouse.x = null; mouse.y = null; });

    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(setup, 250);
    });

    setup();
  });
</script>
