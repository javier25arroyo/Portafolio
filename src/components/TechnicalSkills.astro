---
import Icon from './Icon.astro';

const skills = [
  { name: "Java", iconName: "java", color: "#f89500" },
  { name: "C#", iconName: "csharp", color: "#239120" },
  { name: "HTML", iconName: "html", color: "#e34f26" },
  { name: "CSS", iconName: "css", color: "#1572b6" },
  { name: "JavaScript", iconName: "javascript", color: "#f7df1e" },
  { name: "TypeScript", iconName: "typescript", color: "#3178c6" },
  { name: "Node.js", iconName: "nodejs", color: "#339933" },
  { name: "Angular", iconName: "angular", color: "#dd0031" },
  { name: "MySQL", iconName: "mysql", color: "#4479a1" },
  { name: "SQL Server", iconName: "sqlserver", color: "#cc2927" },
  { name: "Oracle", iconName: "oracle", color: "#f80000" },
  { name: "MongoDB", iconName: "mongodb", color: "#47a248" },
  { name: "GIT", iconName: "git", color: "#f05032" },
  { name: "Azure", iconName: "azure", color: "#0078d4" },
  { name: "Figma", iconName: "figma", color: "#f24e1e" }
];

// Duplicamos las habilidades para el bucle infinito
const infiniteSkills = [...skills, ...skills];
--- 

<div class="skills-marquee-container reveal">
  <div class="skills-track">
    {infiniteSkills.map(skill => (
      <div class="skill-item" style={`--skill-color: ${skill.color};`}>
        <div class="skill-icon">
          <Icon name={skill.iconName} size="lg" />
        </div>
        <span class="skill-label">{skill.name}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .skills-marquee-container {
    width: 100%;
    overflow: hidden;
    padding: 3rem 0;
    background: var(--bg-surface);
    position: relative;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .skills-track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  .skills-marquee-container:hover .skills-track {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .skills-track {
      animation-duration: 60s; /* Más lento en móvil */
    }
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center; /* Centra horizontalmente */
    justify-content: center; /* Centra verticalmente */
    gap: 0.75rem; /* Espacio ajustado entre ícono y texto */
    width: 160px;
    height: 140px;
    flex-shrink: 0;
    box-sizing: border-box;
    padding: 1rem;
    margin: 0 1.5rem;
    background: var(--bg-elevated);
    border-radius: 1rem;
    transition: all var(--transition-normal);
    border: 1px solid transparent;
  }

  .skill-item:hover {
    transform: scale(1.1) translateY(-10px);
    border-color: var(--skill-color);
    background: var(--bg-accent);
    box-shadow: 0 0 30px -5px var(--skill-color);
  }

  .skill-icon {
    width: 56px;
    height: 56px;
    display: flex; /* Centra el SVG/Icono dentro de este div */
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-normal);
  }
  
  .skill-item:hover .skill-icon {
      transform: scale(1.2);
  }

  .skill-label {
    font-weight: 600;
    color: var(--text-secondary);
    text-align: center; /* Centra el texto horizontalmente */
    width: 100%;
    line-height: 1.2;
    height: 2.5em; /* Reserva espacio para un máximo de dos líneas */
    display: flex; /* Permite centrar el texto verticalmente */
    align-items: center; /* Centra verticalmente */
    justify-content: center; /* Centra horizontalmente (para el flex container) */
  }
  
  .skill-item:hover .skill-label {
      color: var(--text-primary);
  }
</style>