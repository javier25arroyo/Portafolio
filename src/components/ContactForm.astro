---
// Contact form component
---
<form class="contact-form" id="contact-form" method="POST" action="/api/contact">
  <div class="form-group">
    <label for="name">Nombre *</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      aria-required="true"
      placeholder="Tu nombre"
    />
  </div>

  <div class="form-group">
    <label for="email">Email *</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      aria-required="true"
      placeholder="tu@email.com"
    />
  </div>

  <div class="form-group">
    <label for="subject">Asunto *</label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      aria-required="true"
      placeholder="¿De qué se trata?"
    />
  </div>

  <div class="form-group">
    <label for="message">Mensaje *</label>
    <textarea
      id="message"
      name="message"
      required
      aria-required="true"
      rows="5"
      placeholder="Tu mensaje aquí..."
    ></textarea>
  </div>

  <div class="form-actions">
    <button type="submit" class="button button--primary">Enviar mensaje</button>
    <div id="form-status" class="form-status" aria-live="polite" aria-atomic="true"></div>
  </div>
</form>

<style>
  .contact-form {
    max-width: 42rem;
    margin: 2rem auto 0;
  }

  .form-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  input,
  textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-light);
    border-radius: 0.5rem;
    background-color: var(--bg-surface);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.2s, background-color 0.2s;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background-color: var(--bg-elevated);
  }

  input:invalid:not(:placeholder-shown),
  textarea:invalid:not(:placeholder-shown) {
    border-color: #ef4444;
  }

  textarea {
    resize: vertical;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .form-status {
    font-size: 0.9rem;
    min-height: 1.5rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
  }

  .form-status.success {
    background-color: rgba(16, 185, 129, 0.1);
    color: #10b981;
  }

  .form-status.error {
    background-color: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  @media (max-width: 768px) {
    .contact-form {
      margin: 1rem 0 0 0;
    }

    .form-group {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      // Validate
      if (!data.name || !data.email || !data.subject || !data.message) {
        if (statusEl) {
          statusEl.textContent = '⚠️ Por favor completa todos los campos';
          statusEl.className = 'form-status error';
        }
        return;
      }

      // Submit (for now just show success message)
      // In production, POST to an API endpoint
      if (statusEl) {
        statusEl.textContent = '✓ Mensaje enviado. Te contactaremos pronto.';
        statusEl.className = 'form-status success';
      }

      // Reset form
      form.reset();

      // Clear status message after 5s
      setTimeout(() => {
        if (statusEl) {
          statusEl.textContent = '';
          statusEl.className = 'form-status';
        }
      }, 5000);
    });
  }
</script>
